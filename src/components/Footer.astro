---
const today = new Date();

// Image assets
const images = {
  logo: '/images/logo-footer.svg',
  twitter: '/images/twitter.svg',
  linkedin: '/images/linkedin.svg',
  instagram: '/images/instagram.svg',
  accessibility: '/images/accessibility.svg',
  cookies: '/images/cookies.svg',
};
---

<footer class="footer">
  <div class="footer-content">
    <div>
      <img src={images.logo} alt="720 Strategies" class="footer-logo" />
    </div>
    
    <nav class="footer-nav">
      <a href="/about">ABOUT</a>
      <a href="#capabilities">OUR CAPABILITIES</a>
      <a href="#work">WORK</a>
      <a href="#contact">CONTACT US</a>
    </nav>
    
    <div class="social-icons">
      <img src={images.twitter} alt="Twitter" class="social-icon" />
      <img src={images.linkedin} alt="LinkedIn" class="social-icon" />
      <img src={images.instagram} alt="Instagram" class="social-icon" />
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>Copyright ©{today.getFullYear()} 720 Strategies. All Rights Reserved.</p>
    <div class="footer-icons">
      <img src={images.accessibility} alt="Accessibility" class="footer-icon" />
      <img src={images.cookies} alt="Cookies" class="footer-icon" />
    </div>
  </div>
</footer>

<style>
  .footer {
    background: black;
    padding: 60px 130px;
    color: white;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 40px;
  }

  .footer-logo {
    height: 65px;
  }

  .footer-nav {
    font-size: 20px;
    line-height: 1.75;
  }

  .footer-nav a {
    color: white;
    text-decoration: none;
    display: block;
  }

  .footer-nav a:hover {
    color: #b21e3b;
  }

  .social-icons {
    display: flex;
    gap: 20px;
    justify-content: flex-end;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  .social-icon:hover {
    opacity: 0.7;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-icons {
    display: flex;
    gap: 20px;
  }

  .footer-icon {
    width: 73px;
    height: 73px;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 40px 20px;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .social-icons {
      justify-content: flex-start;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>
