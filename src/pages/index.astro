---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Image assets
const images = {
  logo: '/images/720-logo-white.svg',
  heroImage: '/images/hero-image.png',
  nav: '/images/nav-icon.svg',
  
  // Expertise images
  publicAffairs: '/images/public-affairs.png',
  healthcare: '/images/healthcare.png',
  grassroots: '/images/grassroots.png',
  pacStrategy: '/images/pac-strategy.png',
  membership: '/images/membership.png',
  mediaRelations: '/images/media-relations.png',
  creative: '/images/creative.png',
  
  // Case study images
  caseStudy1: '/images/case-study-1.png',
  caseStudy2: '/images/case-study-2.png',
  caseStudy3: '/images/case-study-3.png',
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Inter', sans-serif;
        background: white;
        color: #282828;
        overflow-x: hidden;
      }

      /* Hero Section */
      .hero {
        position: relative;
        height: 915px;
        background: linear-gradient(to bottom, rgba(7,7,7,0) 34%, rgba(7,7,7,0.75) 66%, #070707 95%),
                    url('/images/hero-image.png') center/cover;
        color: white;
      }

      .hero-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 94px 100px 0;
      }

      .logo {
        height: 65px;
        width: auto;
        object-fit: contain;
      }

      .nav-icon {
        width: 41px;
        height: 26px;
        cursor: pointer;
      }

      .hero-content {
        text-align: center;
        padding: 200px 20px 0;
      }

      .hero-title {
        font-size: 88px;
        font-weight: 700;
        line-height: 1.08;
        margin-bottom: 40px;
        color: white;
      }

      .hero-title-light {
        font-weight: 300;
        color: white;
      }

      .hero-subtitle {
        font-size: 40px;
        line-height: 1.25;
        max-width: 1145px;
        margin: 0 auto 50px;
        color: white;
      }

      .cta-button {
        display: inline-block;
        background: #b21e3b;
        color: white;
        padding: 15px 40px;
        border: 1px solid white;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 20px;
        text-transform: uppercase;
        transition: all 0.3s;
      }

      .cta-button:hover {
        background: #8f1830;
      }

      /* Red Banner */
      .red-banner {
        background: #b21e3b;
        padding: 60px 20px;
        text-align: center;
      }

      .red-banner p {
        color: white;
        font-size: 22px;
        line-height: 1.68;
        max-width: 967px;
        margin: 0 auto;
      }

      /* Promise & Approach Section */
      .promise-approach {
        padding: 80px 130px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
      }

      .section-title {
        font-size: 40px;
        font-weight: 600;
        margin-bottom: 20px;
        position: relative;
        padding-left: 20px;
      }

      .section-title::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        width: 9px;
        height: 34px;
        background: #b21e3b;
      }

      .section-text {
        font-size: 22px;
        line-height: 1.55;
        color: #282828;
      }

      /* Expertise Section */
      .expertise {
        padding: 80px 130px;
      }

      .expertise-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 40px;
      }

      .expertise-card {
        position: relative;
        height: 430px;
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
      }

      .expertise-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .expertise-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 100%;
        background: linear-gradient(to bottom, rgba(7,7,7,0) 15%, rgba(7,7,7,0.75) 90%);
        display: flex;
        align-items: flex-end;
        padding: 30px;
      }

      .expertise-title {
        color: white;
        font-size: 24px;
        font-weight: 700;
        line-height: 1.4;
      }

      .digital-strategy {
        background: #b21e3b;
        padding: 40px 30px;
        border-radius: 10px;
      }

      .digital-strategy .expertise-title {
        margin-top: 180px;
      }

      .digital-text {
        color: white;
        font-size: 20px;
        line-height: 1.25;
        margin-bottom: 20px;
      }

      /* Case Studies */
      .case-studies {
        padding: 80px 130px;
        text-align: center;
      }

      .case-studies-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 40px;
      }

      .case-study-card {
        position: relative;
        height: 586px;
        border-radius: 10px;
        overflow: hidden;
      }

      .case-study-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .case-study-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px;
        background: linear-gradient(to bottom, rgba(7,7,7,0), #070707);
      }

      .case-study-title {
        color: white;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 15px;
      }

      .case-study-arrow {
        width: 57px;
        height: 57px;
        background: white;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      /* Client Logos */
      .client-logos {
        padding: 60px 130px;
        text-align: center;
      }

      .client-logos p {
        font-size: 22px;
        color: #3c3c3c;
        line-height: 1.55;
        max-width: 820px;
        margin: 0 auto;
      }

      /* Contact Form */
      .contact-form {
        background: linear-gradient(to bottom, #b21e3b 0%, #070707 50%);
        padding: 80px 130px;
        color: white;
      }

      .contact-form h2 {
        font-size: 44px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 20px;
      }

      .contact-form-intro {
        text-align: center;
        font-size: 20px;
        line-height: 1.36;
        max-width: 820px;
        margin: 0 auto 40px;
      }

      .form-grid {
        max-width: 876px;
        margin: 0 auto;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        margin-bottom: 40px;
      }

      .form-field {
        display: flex;
        flex-direction: column;
      }

      .form-field label {
        font-size: 15px;
        margin-bottom: 8px;
      }

      .form-field input,
      .form-field textarea {
        background: transparent;
        border: none;
        border-bottom: 1px solid white;
        color: white;
        padding: 8px 0;
        font-size: 15px;
        font-family: 'Inter', sans-serif;
      }

      .form-field input::placeholder,
      .form-field textarea::placeholder {
        color: rgba(255,255,255,0.5);
      }

      .form-field-full {
        grid-column: 1 / -1;
      }

      textarea {
        min-height: 88px;
        resize: vertical;
      }

      .submit-button {
        display: block;
        margin: 40px auto 0;
        background: #070707;
        color: white;
        border: 1px solid #f1f1f1;
        padding: 15px 60px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 20px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s;
      }

      .submit-button:hover {
        background: #1a1a1a;
      }

      @media (max-width: 1200px) {
        .expertise-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        
        .case-studies-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 768px) {
        .hero-title {
          font-size: 48px;
        }
        
        .hero-subtitle {
          font-size: 24px;
        }
        
        .promise-approach {
          grid-template-columns: 1fr;
          padding: 40px 20px;
        }
        
        .expertise-grid {
          grid-template-columns: 1fr;
        }
        
        .form-row {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <!-- Hero Section -->
    <section class="hero">
      <nav class="hero-nav">
        <img src={images.logo} alt="720 Strategies" class="logo" />
        <img src={images.nav} alt="Menu" class="nav-icon" />
      </nav>
      
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="hero-title-light">Agile by Nature.</span><br />
          Strategic by Design.
        </h1>
        <p class="hero-subtitle">
          A strategic communications and public relations firm connecting people, policy, and technology for <strong>impact</strong>.
        </p>
        <a href="#capabilities" class="cta-button">View Our Capabilities</a>
      </div>
    </section>

    <!-- Red Banner -->
    <section class="red-banner">
      <p>
        720 Strategies delivers human-centered approaches that bring clarity to complex challenges, 
        helping organizations connect meaningfully with their audiences and turn conversations into action.
      </p>
    </section>

    <!-- Promise & Approach -->
    <section class="promise-approach">
      <div>
        <h2 class="section-title">Our Promise</h2>
        <p class="section-text">
          We help organizations modernize, engage the right audiences, and achieve tangible outcomes. 
          By blending empathy with insight, we make complex ideas clear and build trust that drives meaningful change.
        </p>
      </div>
      <div>
        <h2 class="section-title">Our Approach</h2>
        <p class="section-text">
          Our integrated teams balance innovation and accountability to deliver public relations, communications, 
          marketing, and outreach solutions. Every step is collaborative. We adjust as your mission evolves, 
          with a clear focus on results, smart execution, and fiscal responsibility.
        </p>
      </div>
    </section>

    <!-- Expertise Section -->
    <section class="expertise" id="capabilities">
      <h2 class="section-title">Our Expertise</h2>
      
      <div class="expertise-grid">
        <div class="expertise-card">
          <img src={images.publicAffairs} alt="Public Affairs" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Public Affairs<br />& Government<br />Communications</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.healthcare} alt="Healthcare Communications" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Healthcare Communications</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.grassroots} alt="Grassroots Advocacy" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Grassroots<br />Advocacy</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.pacStrategy} alt="PAC Strategy" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">PAC Strategy<br />& Compliance</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.membership} alt="Membership Engagement" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Membership<br />Engagement</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.mediaRelations} alt="Media Relations" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Media<br />Relations</h3>
          </div>
        </div>
        
        <div class="expertise-card">
          <img src={images.creative} alt="Creative" />
          <div class="expertise-overlay">
            <h3 class="expertise-title">Creative</h3>
          </div>
        </div>
        
        <div class="expertise-card digital-strategy">
          <p class="digital-text">
            Engaging audiences where they are with targeted, data-driven campaigns using compelling content 
            and the latest innovative solutions.
          </p>
          <h3 class="expertise-title">Digital<br />Strategy</h3>
        </div>
      </div>
      
      <div style="text-align: center; margin-top: 60px;">
        <a href="#contact" class="cta-button">View Our Capabilities</a>
      </div>
    </section>

    <!-- Case Studies -->
    <section class="case-studies">
      <h2 class="section-title" style="display: inline-block;">Our Work/ Case Studies</h2>
      
      <div class="case-studies-grid">
        <div class="case-study-card">
          <img src={images.caseStudy1} alt="Case Study 1" />
          <div class="case-study-overlay">
            <h3 class="case-study-title">Case Study<br />Project 1</h3>
            <div class="case-study-arrow">→</div>
          </div>
        </div>
        
        <div class="case-study-card">
          <img src={images.caseStudy2} alt="Case Study 2" />
          <div class="case-study-overlay">
            <h3 class="case-study-title">Case Study<br />Project 2</h3>
            <div class="case-study-arrow">→</div>
          </div>
        </div>
        
        <div class="case-study-card">
          <img src={images.caseStudy3} alt="Case Study 3" />
          <div class="case-study-overlay">
            <h3 class="case-study-title">Case Study<br />Project 3</h3>
            <div class="case-study-arrow">→</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Client Logos Section -->
    <section class="client-logos">
      <p>
        We have worked with Fortune 500s, non-profits, and associations to help engage their customers, 
        constituents, and members, both online and offline.
      </p>
    </section>

    <!-- Contact Form -->
    <section class="contact-form" id="contact">
      <h2>Less About Us. More About You.</h2>
      <p class="contact-form-intro">
        Start by sharing a few details below and we'll take it from there.<br />
        Your story guides the conversation and shapes what comes next.
      </p>
      
      <form class="form-grid">
        <div class="form-row">
          <div class="form-field">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" />
          </div>
          <div class="form-field">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" />
          </div>
        </div>
        
        <div class="form-row">
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" />
          </div>
          <div class="form-field">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" />
          </div>
        </div>
        
        <div class="form-field form-field-full">
          <label for="comment">Comment</label>
          <textarea id="comment" name="comment"></textarea>
        </div>
        
        <button type="submit" class="submit-button">Submit Form</button>
      </form>
    </section>

    <Footer />
  </body>
</html>
